# Runtime secrets for `wrangler dev`.
# Copy this file to `.dev.vars` and fill values locally.

# DeepSeek via Cloudflare AI Gateway
DEEPSEEK_API_KEY=
CF_ACCOUNT_ID=
CF_AI_GATEWAY_ID=xms-dialogue-game
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
DEEPSEEK_REPORT_MODEL=deepseek-v4-pro

# App runtime
APP_BASE_URL=http://127.0.0.1:8080
SESSION_SECRET=
ADMIN_TOKEN=

# Hermes Orchestrator
HERMES_WEBHOOK_SECRET=
HERMES_MOCK=true
HERMES_API_BASE=http://127.0.0.1:8787

# ClawBot webhook security
CLAWBOT_WEBHOOK_SECRET=
CLAWBOT_MOCK=true

# BufPay payment provider
BUFPAY_AID=
BUFPAY_SECRET=
BUFPAY_MOCK=true

# PWA web push, optional for MVP until notification sending is implemented
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Local operator environment.
# Copy to `.env` for your machine. Do not commit real values.

# Cloudflare CLI / deployment
CLOUDFLARE_API_TOKEN=
CF_ACCOUNT_ID=
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare resource IDs created for this project
CF_D1_DATABASE_NAME=xms-dialogue-game
CF_D1_DATABASE_ID=
CF_KV_NAMESPACE_ID=
CF_KV_PREVIEW_NAMESPACE_ID=
CF_R2_BUCKET_NAME=xms-dialogue-game-assets
CF_QUEUE_NAME=xms-dialogue-game-ai
CF_AI_GATEWAY_ID=xms-dialogue-game

# Public app URLs
APP_BASE_URL=http://127.0.0.1:8080
PRODUCTION_APP_BASE_URL=

# DeepSeek via Cloudflare AI Gateway
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
DEEPSEEK_REPORT_MODEL=deepseek-v4-pro

# ClawBot webhook security
CLAWBOT_WEBHOOK_SECRET=
CLAWBOT_MOCK=false

# BufPay payment provider
BUFPAY_AID=
BUFPAY_SECRET=
BUFPAY_MOCK=false

# Session / security
# Generate with: openssl rand -base64 48
SESSION_SECRET=
ADMIN_TOKEN=

# PWA web push, optional for MVP until notification sending is implemented
# Generate later with a VAPID key tool if enabling browser push notifications.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optional custom domain deployment
CF_ZONE_NAME=
CF_ZONE_ID=
CF_WORKER_ROUTE=
